{
  "name": "quickui-design",
  "version": "1.0.0",
  "description": "QuickUI-Design, a UE5-UI design toolkit using React to design UE5's UI interactive interfaces.",
  "main": "index.js",
  "scripts": {
    "dev": "rspack serve --mode development",
    "build": "rspack --mode production && prettier \"dist/*.html\" --write",
    "merge-html": "node assets-tool/merge-html.js",
    "base64img": "node assets-tool/convertImageToBase64.js ./src/assets/img/",
    "prettier": "prettier \"src/**/*.{ts,tsx}\" --write",
    "lint": "eslint \"src/**/*.{ts,js,json,jsx,tsx}\"  --ignore-pattern \"src/utils/HTMLMenuUE4Connector.js\" ",
    "format:lint": "eslint \"src/**/*.{ts,js,json,jsx,tsx}\" --fix --ignore-pattern \"src/utils/HTMLMenuUE4Connector.js\" ",
    "formatfix": "prettier \"src/**/*.{ts,js,json,jsx,tsx}\" --write && eslint \"src/**/*.{ts,js,json,jsx,tsx}\" --fix --ignore-pattern \"src/utils/HTMLMenuUE4Connector.js\""
  },
  "browser": {
    "@": "./src"
  },
  "keywords": [],
  "author": "MarcoTin<277924771@qq.com>",
  "license": "Proprietary - All Rights Reserved",
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.3",
    "@rspack/cli": "^1.3.9",
    "@rspack/core": "^1.3.9",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "autoprefixer": "^10.4.20",
    "babel-loader": "^9.2.1",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.3",
    "html-webpack-plugin": "^5.6.3",
    "postcss": "^8.4.49",
    "postcss-loader": "^8.1.1",
    "postcss-preset-env": "^10.1.3",
    "raw-loader": "^4.0.2",
    "style-loader": "^4.0.0",
    "tailwindcss": "~3.4.17",
    "ts-loader": "^9.4.3",
    "typescript": "^5.1.6",
    "url-loader": "^4.1.1"
  },
  "dependencies": {
    "autofit.js": "^3.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "file-loader": "^6.2.0",
    "path": "^0.12.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.1.1",
    "styled-components": "^6.1.18",
    "tailwind-merge": "~2.6.0",
    "tailwindcss-animate": "~1.0.7",
    "ue-connect": "./ue-connect"
  }
}
