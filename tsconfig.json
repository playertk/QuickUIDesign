{
  "compilerOptions": {
    "outDir": "./dist/",
    "noImplicitAny": true,
    "module": "esnext",
    "target": "es2015",
    "lib": ["dom", "dom.iterable", "es2015"],
    "jsx": "react-jsx",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "lenis/react": ["node_modules/lenis/dist/lenis-react"],
      "@dev/*": ["./src/dev-tools/*"],
      "clickdeck-core": ["./clickdeck-core/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"]
}
